{
  "name": "convertertomarkdown-mcp",
  "version": "1.0.0",
  "description": "MCP server to convert files (DOCX, PDF, XLSX, HTML, CSV, JSON, XML, images) to Markdown — Node.js, no browser required",
  "type": "module",
  "license": "MIT",
  "author": "Francisco Valero",
  "homepage": "https://convertertomarkdown.com",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "markdown",
    "converter",
    "docx",
    "pdf",
    "xlsx",
    "html",
    "ocr",
    "llm",
    "ai"
  ],
  "bin": {
    "convertertomarkdown-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "jsdom": "^25.0.0",
    "mammoth": "^1.12.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^3.11.174",
    "tesseract.js": "^7.0.0",
    "turndown": "^7.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/jsdom": "^21.0.0",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0"
  }
}
